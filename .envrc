dotenv_if_exists .env.local

use flake
uv sync
source .venv/bin/activate

if [ -z "${AWS_PROFILE:-}" ]; then
  echo "AWS_PROFILE not set — add 'export AWS_PROFILE=<your-profile>' to .env.local"
else
  if ! aws sts get-caller-identity &>/dev/null; then
    echo "AWS SSO session expired — run: aws sso login"
  else
    export FRED_API_KEY=$(aws secretsmanager get-secret-value \
      --secret-id fred/api-key --query SecretString --output text 2>/dev/null || true)
  fi
fi
